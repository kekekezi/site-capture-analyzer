{
  "name": "site-capture-extension",
  "version": "0.1.0",
  "private": true,
  "description": "A local Chrome/Edge extension for recording website sessions, network activity, storage, screenshots, and user behavior into an exportable analysis package.",
  "license": "MIT",
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "website-analysis",
    "network-capture",
    "session-recorder",
    "debugging"
  ],
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "jszip": "^3.10.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "@types/node": "^24.0.0",
    "puppeteer-core": "^25.3.0"
  }
}
